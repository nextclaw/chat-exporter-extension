{
  "manifest_version": 3,
  "name": "Chat Exporter",
  "version": "0.1.2",
  "description": "Export the current ChatGPT, Gemini, or Claude conversation to local JSON, Markdown, and asset files.",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "downloads", "scripting"],
  "action": {
    "default_title": "Export current chat",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://app.claude.ai/*"
      ],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
