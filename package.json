{
  "name": "chat-exporter-extension",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "NextClaw <zizhizhan@gmail.com> (https://github.com/nextclaw)",
  "repository": {
    "type": "git",
    "url": "https://github.com/nextclaw/chat-exporter-extension.git"
  },
  "homepage": "https://github.com/nextclaw/chat-exporter-extension#readme",
  "bugs": {
    "url": "https://github.com/nextclaw/chat-exporter-extension/issues"
  },
  "description": "Chrome extension for exporting the current ChatGPT, Gemini, or Claude conversation to local JSON, Markdown, and image files.",
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && vite build && vite build --config vite.content.config.ts && node scripts/validate-build.mjs",
    "package": "npm run build && node scripts/package-extension.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/chrome": "^0.0.315",
    "@types/node": "^22.15.3",
    "eslint": "^9.25.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  }
}
